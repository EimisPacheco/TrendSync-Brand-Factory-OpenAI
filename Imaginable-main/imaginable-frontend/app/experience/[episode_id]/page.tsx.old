"use client";

import { useEffect, useState, useRef } from "react";
import { useParams, useRouter } from "next/navigation";

type SceneMetadata = {
  scene_number: number;
  interaction: boolean;
  prompt: string;
  dialogue: string;
  task?: string;
  expected_response?: string;
};

type Episode = {
  episode_id: string;
  title: string;
  description: string;
  scene_video_urls: string[];
  scene_feedback_urls: Array<{ correct_url: string; incorrect_url: string } | null>;
  scene_idle_urls: Array<string | null>;
  scene_metadata: SceneMetadata[];
};

export default function ExperiencePage() {
  const params = useParams();
  const router = useRouter();
  const episode_id = params.episode_id as string;
  
  const [episode, setEpisode] = useState<Episode | null>(null);
  const [currentSceneIndex, setCurrentSceneIndex] = useState(0);
  const [isLoading, setIsLoading] = useState(true);
  const [showInteractionOverlay, setShowInteractionOverlay] = useState(false);
  const [currentTime, setCurrentTime] = useState(0);
  const [duration, setDuration] = useState(0);
  
  const videoRef = useRef<HTMLVideoElement>(null);

  useEffect(() => {
    const fetchEpisode = async () => {
      setIsLoading(true);
      try {
        const response = await fetch(`http://localhost:8001/episodes/${episode_id}`);
        if (response.ok) {
          const data = await response.json();
          setEpisode(data);
        } else {
          console.error("Failed to fetch episode");
        }
      } catch (error) {
        console.error("Error fetching episode:", error);
      } finally {
        setIsLoading(false);
      }
    };

    if (episode_id) {
      fetchEpisode();
    }
  }, [episode_id]);

  useEffect(() => {
    if (episode && videoRef.current) {
      videoRef.current.load();
      videoRef.current.play();
    }
  }, [currentSceneIndex, episode]);

  const handleVideoEnded = () => {
    const currentScene = episode?.scene_metadata[currentSceneIndex];
    
    if (currentScene?.interaction) {
      // Pause for interaction
      setShowInteractionOverlay(true);
    } else {
      // Move to next scene
      if (episode && currentSceneIndex < episode.scene_metadata.length - 1) {
        setCurrentSceneIndex(currentSceneIndex + 1);
      }
    }
  };

  const handleInteractionComplete = () => {
    setShowInteractionOverlay(false);
    
    // Move to next scene
    if (episode && currentSceneIndex < episode.scene_metadata.length - 1) {
      setCurrentSceneIndex(currentSceneIndex + 1);
    }
  };

  const handleTimeUpdate = () => {
    if (videoRef.current) {
      setCurrentTime(videoRef.current.currentTime);
    }
  };

  const handleLoadedMetadata = () => {
    if (videoRef.current) {
      setDuration(videoRef.current.duration);
    }
  };

  const handleSeek = (e: React.MouseEvent<HTMLDivElement>) => {
    if (videoRef.current && duration) {
      const rect = e.currentTarget.getBoundingClientRect();
      const pos = (e.clientX - rect.left) / rect.width;
      videoRef.current.currentTime = pos * duration;
    }
  };

  const formatTime = (seconds: number) => {
    const mins = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    return `${mins}:${secs.toString().padStart(2, '0')}`;
  };

  const handleSceneClick = (index: number) => {
    setCurrentSceneIndex(index);
  };

  if (isLoading) {
    return (
      <div className="flex min-h-screen items-center justify-center bg-zinc-50">
        <div className="animate-spin rounded-full h-16 w-16 border-b-4 border-orange-500"></div>
      </div>
    );
  }

  if (!episode || !episode.scene_metadata || episode.scene_metadata.length === 0) {
    return (
      <div className="flex min-h-screen items-center justify-center bg-zinc-50">
        <div className="text-center">
          <h1 className="text-2xl font-bold text-gray-800 mb-4">Episode not found</h1>
          <button
            onClick={() => router.push("/")}
            className="px-6 py-2 bg-orange-500 text-white rounded-full hover:bg-orange-600"
          >
            Back to Home
          </button>
        </div>
      </div>
    );
  }

  const currentVideoUrl = episode.scene_video_urls[currentSceneIndex];

  return (
    <div className="relative flex min-h-screen flex-col bg-zinc-50">
      {/* Header */}
      <header className="relative z-10 w-full px-8 py-6">
        <div className="flex items-center justify-between">
          <div className="flex items-center gap-4">
            <button
              onClick={() => router.push("/")}
              className="text-gray-600 hover:text-gray-800"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
              </svg>
            </button>
            <h1 className="text-2xl font-bold text-gray-800" style={{ fontFamily: 'var(--font-adamina)' }}>
              {episode.title}
            </h1>
          </div>
        </div>
      </header>

      {/* Video Player */}
      <div className="flex-1 flex flex-col items-center justify-center px-8 pb-8">
        <div className="relative w-full max-w-6xl aspect-video bg-black rounded-2xl overflow-hidden shadow-2xl">
          <video
            ref={videoRef}
            src={currentVideoUrl}
            className="w-full h-full object-contain"
            onEnded={handleVideoEnded}
            onTimeUpdate={handleTimeUpdate}
            onLoadedMetadata={handleLoadedMetadata}
            autoPlay
          />

          {/* Interaction Overlay */}
          {showInteractionOverlay && episode.scene_metadata[currentSceneIndex]?.interaction && (
            <div className="absolute inset-0 bg-black/80 flex items-center justify-center z-20">
              <div className="bg-white rounded-2xl p-8 max-w-2xl mx-4">
                <h2 className="text-2xl font-bold text-gray-800 mb-4" style={{ fontFamily: 'var(--font-adamina)' }}>
                  Interactive Challenge
                </h2>
                <p className="text-lg text-gray-700 mb-4">{episode.scene_metadata[currentSceneIndex].dialogue}</p>
                {episode.scene_metadata[currentSceneIndex].task && (
                  <p className="text-md text-gray-600 mb-6 italic">{episode.scene_metadata[currentSceneIndex].task}</p>
                )}
                <button
                  onClick={handleInteractionComplete}
                  className="w-full px-6 py-3 bg-orange-500 text-white rounded-full font-semibold hover:bg-orange-600 transition-all"
                >
                  Continue
                </button>
              </div>
            </div>
          )}
        </div>

        {/* Video Timeline */}
        <div className="w-full max-w-6xl mt-6">
          {/* Time Display */}
          <div className="flex justify-between text-sm text-gray-600 mb-2">
            <span>{formatTime(currentTime)}</span>
            <span>{formatTime(duration)}</span>
          </div>
          
          {/* Progress Bar */}
          <div 
            className="relative h-2 bg-gray-300 rounded-full cursor-pointer hover:h-3 transition-all"
            onClick={handleSeek}
          >
            <div 
              className="absolute h-full bg-orange-500 rounded-full"
              style={{ width: `${duration ? (currentTime / duration) * 100 : 0}%` }}
            />
          </div>
          
          {/* Scene Markers */}
          <div className="flex items-center justify-center gap-2 mt-4">
            {episode.scene_metadata.map((scene: SceneMetadata, index: number) => (
              <button
                key={scene.scene_number}
                onClick={() => handleSceneClick(index)}
                className={`w-2 h-2 rounded-full transition-all ${
                  index === currentSceneIndex
                    ? 'bg-orange-500 scale-150'
                    : index < currentSceneIndex
                    ? 'bg-orange-300'
                    : 'bg-gray-300 hover:bg-gray-400'
                }`}
                aria-label={`Scene ${scene.scene_number}`}
              />
            ))}
          </div>
        </div>
      </div>
    </div>
  );
}
